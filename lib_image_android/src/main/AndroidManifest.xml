<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config">

        <service
            android:name="com.afkanerd.lib_image_android.ui.services.ImageTransmissionService"
            android:exported="false"
            android:foregroundServiceType="dataSync">
            <intent-filter>
                <action android:name="androidx.work.impl.foreground.SystemForegroundService" />
            </intent-filter>
        </service>

        <receiver
            android:name="com.afkanerd.lib_image_android.ui.receivers.NotificationActionImpl"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.afkanerd.lib_image_android.NOTIFICATION_STOP_ACTION_INTENT_ACTION" />
                <action android:name="com.afkanerd.lib_image_android.NOTIFICATION_PAUSE_ACTION_INTENT_ACTION" />
            </intent-filter>
        </receiver>

    </application>

</manifest>